# Base URL of the Sardia backend API. Leave empty in production — the
# Cloudflare Pages Function at /functions/api/[[path]].ts proxies same-origin
# so the auth cookie stays first-party.
VITE_API_BASE_URL="http://localhost:5001"

# Optional. If set, browser errors + traces are sent to Sentry.
# Get a DSN from https://sentry.io → Project Settings → Client Keys.
# Set this in Cloudflare Pages → Settings → Environment variables (production).
VITE_SENTRY_DSN=
